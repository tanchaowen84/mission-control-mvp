generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

model Mission {
  id        String   @id @default(cuid())
  statement String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  tasks       Task[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  projectId   String?
  assigneeId  String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    Agent?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([assigneeId])
}

model Memory {
  id         String   @id @default(cuid())
  title      String
  content    String
  tags       Json
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([occurredAt])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  fileName    String
  contentType String
  description String?
  textContent String?
  sourceUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([title])
  @@index([fileName])
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  role          String
  device        String
  mission       String
  parentId      String?
  parent        Agent?   @relation("AgentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Agent[]  @relation("AgentHierarchy")
  assignedTasks Task[]   @relation("TaskAssignee")
  desk          Desk?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([parentId])
}

model Job {
  id             String   @id @default(cuid())
  name           String
  cronExpression String
  nextRun        DateTime
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([enabled])
  @@index([nextRun])
}

model Desk {
  id        String   @id @default(cuid())
  label     String
  x         Int
  y         Int
  agentId   String?  @unique
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([x, y])
}
